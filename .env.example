PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
BETTER_AUTH_SECRET=change_this_to_a_secure_random_string
BETTER_AUTH_URL=http://localhost:3000
DATABASE_URL=postgres://user:password@host:5432/fdrpkm
# Database file for local development (PGLite). This is used when NODE_ENV=development and DATABASE_URL is not set. You can change this to a different path if you want to use a different file.
DATABASE_FILE=./local.db

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Shared secret for the /v1/dev/* endpoints (see docs/dev-endpoints.md). Required even in
# development — unset means every dev endpoint call is rejected. Staging runs in development
# mode on a public URL, so keep this long and random there.
DEV_API_KEY=pick_a_long_random_string

# S3-compatible object storage for uploads (Cloudflare R2 or any S3 API). See docs/upload-guide.md.
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=fdrpkm-uploads
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
# Public bucket/CDN domain to build read URLs from. Leave unset to use presigned GET URLs instead.
ASSET_BASE_URL=