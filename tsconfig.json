{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "paths": {
      "@src/": ["./src"],
      "@src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "eslint.config.js"],
  "exclude": ["dist", "node_modules"]
}
